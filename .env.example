# Copy this file to .env and fill in real values. Never commit .env.

# Application
ENVIRONMENT=development

# Required — generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Required — public base URL of the API (no trailing slash)
# Local uvicorn: http://localhost:8000
# Docker + nginx: http://localhost/api
PUBLIC_API_URL=

# Optional — Google OAuth client id (needed for /auth/google/register)
GOOGLE_CLIENT_ID=

# Required — PostgreSQL (asyncpg driver)
# Local: postgresql+asyncpg://USER:PASSWORD@localhost:5432/DATABASE
# Docker Compose: postgresql+asyncpg://USER:PASSWORD@db:5432/DATABASE
DATABASE_URL=

# Development: create_all on startup (convenient for local dev).
# Production: must be false — schema only via Alembic (alembic upgrade head).
AUTO_CREATE_DB=true

# Log every SQL statement. Always off in production (ENVIRONMENT=production).
SQL_ECHO=false

# Docker backend: run alembic upgrade head before gunicorn (default true in container).
RUN_MIGRATIONS_ON_STARTUP=true

# PostgreSQL backups (docker-compose db-backup service)
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging (development: DEBUG; production: INFO or WARNING)
LOG_LEVEL=DEBUG
# Dev-only: log redacted request headers at DEBUG (never in production)
LOG_VERBOSE_REQUESTS=false

# Error monitoring (optional — https://sentry.io or self-hosted)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Payments — required secret for /payment/callback
PAYMENT_CALLBACK_SECRET=
# Optional override; default is ${PUBLIC_API_URL}/payment/callback
# PAYMENT_CALLBACK_URL=
PAYMENT_ALLOW_TEST=true
WEBPAY_API_URL=http://localhost:8001/payment

# Rate limiting (POST /token, /register, /refresh, /payment/callback)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Email verification on registration (dev: false, prod: true)
REQUIRE_EMAIL_VERIFICATION=false

# Uptime alerts when /health is degraded (Slack/Discord webhook JSON)
UPTIME_ALERT_WEBHOOK_URL=
HEALTH_ALERT_COOLDOWN_SECONDS=300

# Docker / production backend (gunicorn + uvicorn workers)
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# File storage (local paths or mounted volumes)
UPLOADS_FOLDER=uploads
AVATARS_DIR=avatars
PORTFOLIO_DIR=portfolio

# local = filesystem (use Docker volumes in prod)
# s3 = S3-compatible object storage (MinIO, AWS S3) — required for multiple backend instances
FILE_STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=fixer-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# Docker Compose only (postgres service)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
